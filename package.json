    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vite-plugin-devtools-json": "^1.0.0",
    "wrangler": "^4.63.0"
  },
  "dependencies": {
    "@lucide/svelte": "^0.577.0",
    "axios": "^1.13.6",
    "d3-array": "^3.2.4",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "dotenv": "^17.3.1",
    "layerchart": "2.0.0-next.46",
